<!DOCTYPE html>

<html lang="en">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">

<title>Piyush Tech Notes</title>

<link rel="icon" type="image/x-icon" href="w3images/favicon.jpg">

<link rel="stylesheet" href="music.css">
<link rel="stylesheet" href="note.CSS">

<div class="header">
  <button onclick="loadPage('welcome.html')" 
          style="position:absolute; right:20px; top:15px;
                 padding:10px 24px; background:#d21818; color:#fff;
                 border:none; border-radius:4px; cursor:pointer;
                 font-size:14px; font-weight:bold;">
    🏠
  </button>
</div>


<style>

body {
  margin: 0;
  font-family: Verdana, sans-serif;
  background: #000;   /* black background */
  color: #fff;        /* white text */
}


/* HEADER */

/*.header{
background-color: #43464B;	   /* Black background */
color:white;
padding:25px;
text-align:center;
position:relative;
}*/


.header {
  background-color: #43464B;          /* fallback steel grey */
  background-image: url('my-notes/book_shelf.jpg'); /* replace with your image path */
  background-size: cover;             /* scale image to cover entire header */
  background-position: center;        /* center the image */
  color: white;
  padding: 25px;
  text-align: center;
  position: relative;
}



/* LAST UPDATED */

.update{
position:absolute;
top:8px;
right:15px;
font-size:11px;
color:#ccc;
}

/* LAYOUT */

.container{
display:flex;
min-height:90vh;
flex:1;
}

/* SIDEBAR */

.sidebar{
width:260px;
background:#111;
color:white;
overflow-y:auto;
padding-bottom:50px;
}

.sidebar input{
width:85%;
margin:10px;
padding:6px;
}

.sidebar a{
display:block;
padding:8px 15px;
color:white;
text-decoration:none;
font-size:14px;
}

.sidebar a:hover{
background:#d21818;
}

/* COLLAPSIBLE */

.collapsible{
background:#333;
color:white;
cursor:pointer;
padding:10px;
width:100%;
border:none;
text-align:left;
font-size:15px;
}

.collapsible:hover{
background:#d21818;
}

.collapsible-content{
display:none;
}

/* CONTENT */

.content {
  flex: 1;
  padding: 20px;
  background: #000;   /* black background */
  color: #fff;        /* white text */
  display: flex;
  flex-direction: column;
}

/* FOOTER */

.footer{
text-align:center;
background:#d21818;
color:white;
padding:4px 10px;
font-size:11px;
margin-top:auto;
line-height:1.2;
}

/* SPLASH */

#splash{
position:fixed;
width:100%;
height:100%;
background:black;
color:white;
display:flex;
align-items:center;
justify-content:center;
font-size:28px;
cursor:pointer;
z-index:9999;
}

</style>

<script src="music.js"></script>

<script>

/* SPLASH */

function start(){

document.getElementById("splash").style.display="none"
document.getElementById("bgm").play()

}

/* LOAD PAGE */

function loadPage(page){

document.getElementById("viewer").src = page

}

/* COLLAPSIBLE */

function toggleMenu(btn){

let content = btn.nextElementSibling

if(content.style.display==="block")
content.style.display="none"
else
content.style.display="block"

}

/* SEARCH */

function searchNotes(){

let input=document.getElementById("search").value.toLowerCase()

let links=document.querySelectorAll(".sidebar a")

links.forEach(function(link){

if(link.textContent.toLowerCase().includes(input))
link.style.display="block"
else
link.style.display="none"

})

}

</script>

</head>

<body>

<!-- SPLASH -->

<div id="splash" onclick="start()">🎵 Welcome to Piyush Notes - Click to Enter</div>

<audio id="bgm" src="beautiful-piano-logo-143488.mp3"></audio>

<!-- HEADER -->

<div class="header">

<h2></h2>

<p></p>

</div>

<div class="container">

<!-- SIDEBAR -->

<div class="sidebar">

<input id="search" placeholder="Search notes..." onkeyup="searchNotes()">

<script>
function searchNotes() {
  let input = document.getElementById("search").value.toLowerCase();
  let links = document.querySelectorAll(".sidebar a");

  links.forEach(function(link) {
    let text = link.textContent.toLowerCase();

    if (text.includes(input)) {
      link.style.display = "block";

      // Expand parent collapsible section if hidden
      let parent = link.closest(".collapsible-content");
      if (parent) {
        parent.style.display = "block";
      }
    } else {
      link.style.display = "none";
    }
  });

  // Reset all links if search box is empty
  if (input === "") {
    links.forEach(function(link) {
      link.style.display = "block";
    });
  }
}
</script>


